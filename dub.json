{
    "name": "d-cycles",
    "description": "D bindings for a thin C shim around Blender's Cycles X path tracer. Self-contained: lflags below pull in all transitive Cycles static libs + Blender precompiled deps (OIIO, OIDN, Embree, TBB, etc.).",
    "license": "BSL-1.0",
    "authors": ["Alexander Shagarov"],

    "targetType": "staticLibrary",

    "sourcePaths": ["source"],
    "importPaths": ["source"],

    "preBuildCommands-linux": [
        "cd \"$PACKAGE_DIR\" && GIT_LFS_SKIP_SMUDGE=1 git submodule update --init extern/blender",
        "cd \"$PACKAGE_DIR\" && git -C extern/blender config --local submodule.lib/linux_x64.update checkout",
        "cd \"$PACKAGE_DIR\" && git -C extern/blender submodule update --init --depth 1 lib/linux_x64",
        "cd \"$PACKAGE_DIR\" && test -f extern/blender/build_cycles/lib/libcycles_session.a || bash tools/build_cycles_libs.sh",
        "cd \"$PACKAGE_DIR\" && cmake -S \"$PACKAGE_DIR\" -B \"$PACKAGE_DIR/build\" -DCMAKE_BUILD_TYPE=Release -DWITH_CYCLES=ON",
        "cmake --build \"$PACKAGE_DIR/build\" -j --target cyclesc"
    ],

    "preBuildCommands-osx": [
        "cd \"$PACKAGE_DIR\" && GIT_LFS_SKIP_SMUDGE=1 git submodule update --init extern/blender",
        "cd \"$PACKAGE_DIR\" && git -C extern/blender config --local submodule.lib/macos_arm64.update checkout",
        "cd \"$PACKAGE_DIR\" && git -C extern/blender submodule update --init --depth 1 lib/macos_arm64",
        "cd \"$PACKAGE_DIR\" && test -f extern/blender/build_cycles/lib/libcycles_session.a || bash tools/build_cycles_libs.sh",
        "cd \"$PACKAGE_DIR\" && cmake -S \"$PACKAGE_DIR\" -B \"$PACKAGE_DIR/build\" -DCMAKE_BUILD_TYPE=Release -DWITH_CYCLES=ON",
        "cmake --build \"$PACKAGE_DIR/build\" -j --target cyclesc"
    ],

    "preBuildCommands-windows": [
        "git -c filter.lfs.smudge= -c filter.lfs.process= -c filter.lfs.required=false -C \"$PACKAGE_DIR\" submodule update --init extern/blender",
        "git -C \"$PACKAGE_DIR/extern/blender\" config --local submodule.lib/windows_x64.update checkout",
        "git -C \"$PACKAGE_DIR/extern/blender\" submodule update --init --depth 1 lib/windows_x64",
        "cmake -S \"$PACKAGE_DIR/extern/blender\" -B \"$PACKAGE_DIR/extern/blender/build_cycles\" -DCMAKE_PROJECT_INCLUDE=\"$PACKAGE_DIR/tools/win_cycles_project.cmake\" -DCMAKE_BUILD_TYPE=Release -DCMAKE_CXX_STANDARD=17 -DWITH_BLENDER=OFF -DWITH_CYCLES=ON -DWITH_CYCLES_STANDALONE=ON -DWITH_CYCLES_STANDALONE_GUI=OFF -DWITH_CYCLES_HYDRA_RENDER_DELEGATE=OFF -DWITH_CYCLES_TEST=OFF -DWITH_CYCLES_DEVICE_CUDA=OFF -DWITH_CYCLES_DEVICE_OPTIX=OFF -DWITH_CYCLES_CUDA_BINARIES=OFF -DWITH_CYCLES_DEVICE_HIP=OFF -DWITH_CYCLES_DEVICE_ONEAPI=OFF -DWITH_CYCLES_HIP_BINARIES=OFF -DWITH_CYCLES_DEVICE_METAL=OFF -DWITH_CYCLES_EMBREE=ON -DWITH_CYCLES_OSL=OFF -DWITH_CYCLES_OPENSUBDIV=OFF -DWITH_CYCLES_PATH_GUIDING=OFF -DWITH_OPENIMAGEDENOISE=ON -DWITH_OPENCOLORIO=ON -DWITH_OPENVDB=OFF -DWITH_NANOVDB=OFF -DWITH_ALEMBIC=OFF -DWITH_USD=OFF -DWITH_MATERIALX=OFF -DWITH_HYDRA=OFF -DWITH_PYTHON=ON -DWITH_PYTHON_MODULE=OFF -DWITH_AUDASPACE=OFF -DWITH_OPENAL=OFF -DWITH_CODEC_FFMPEG=OFF -DWITH_CODEC_SNDFILE=OFF -DWITH_SDL=OFF -DWITH_INTERNATIONAL=OFF -DWITH_INPUT_NDOF=OFF -DWITH_XR_OPENXR=OFF -DWITH_DRACO=OFF -DWITH_LIBMV=OFF -DWITH_OPENCOLLADA=OFF -DWITH_FFTW3=OFF -DWITH_BULLET=OFF -DWITH_GMP=OFF -DWITH_MANIFOLD=OFF -DWITH_HARU=OFF -DWITH_MOD_FLUID=OFF -DWITH_MOD_OCEANSIM=OFF -DWITH_HARFBUZZ=OFF -DWITH_FRIBIDI=OFF -DWITH_POTRACE=OFF -DWITH_QUADRIFLOW=OFF -DWITH_UV_SLIM=OFF -DWITH_IMAGE_OPENEXR=ON -DWITH_IMAGE_OPENJPEG=ON -DWITH_IMAGE_WEBP=ON -DWITH_IMAGE_CINEON=OFF -DWITH_IO_WAVEFRONT_OBJ=OFF -DWITH_IO_PLY=OFF -DWITH_IO_STL=OFF -DWITH_IO_FBX=OFF -DWITH_IO_GREASE_PENCIL=OFF -DWITH_GHOST_SDL=OFF",
        "cmake --build \"$PACKAGE_DIR/extern/blender/build_cycles\" --target cycles --config Release -j",
        "cmake -S \"$PACKAGE_DIR\" -B \"$PACKAGE_DIR/build\" -DCMAKE_BUILD_TYPE=Release -DWITH_CYCLES=ON",
        "cmake --build \"$PACKAGE_DIR/build\" --target cyclesc --config Release -j"
    ],

    "lflags-linux": [
        "-L$PACKAGE_DIR/build",
        "-L$PACKAGE_DIR/extern/blender/build_cycles/lib",

        "-rpath=$$ORIGIN/lib",
        "-rpath=$PACKAGE_DIR/extern/blender/lib/linux_x64/openimageio/lib",
        "-rpath=$PACKAGE_DIR/extern/blender/lib/linux_x64/opencolorio/lib",
        "-rpath=$PACKAGE_DIR/extern/blender/lib/linux_x64/embree/lib",
        "-rpath=$PACKAGE_DIR/extern/blender/lib/linux_x64/openimagedenoise/lib",
        "-rpath=$PACKAGE_DIR/extern/blender/lib/linux_x64/openexr/lib",
        "-rpath=$PACKAGE_DIR/extern/blender/lib/linux_x64/imath/lib",
        "-rpath=$PACKAGE_DIR/extern/blender/lib/linux_x64/opensubdiv/lib",
        "-rpath=$PACKAGE_DIR/extern/blender/lib/linux_x64/dpcpp/lib",
        "-rpath=$PACKAGE_DIR/extern/blender/lib/linux_x64/tbb/lib",

        "--start-group",
        "$PACKAGE_DIR/build/libcyclesc.a",
        "$PACKAGE_DIR/extern/blender/build_cycles/lib/libcycles_session.a",
        "$PACKAGE_DIR/extern/blender/build_cycles/lib/libcycles_scene.a",
        "$PACKAGE_DIR/extern/blender/build_cycles/lib/libcycles_kernel.a",
        "$PACKAGE_DIR/extern/blender/build_cycles/lib/libcycles_device.a",
        "$PACKAGE_DIR/extern/blender/build_cycles/lib/libcycles_integrator.a",
        "$PACKAGE_DIR/extern/blender/build_cycles/lib/libcycles_bvh.a",
        "$PACKAGE_DIR/extern/blender/build_cycles/lib/libcycles_subd.a",
        "$PACKAGE_DIR/extern/blender/build_cycles/lib/libcycles_graph.a",
        "$PACKAGE_DIR/extern/blender/build_cycles/lib/libcycles_util.a",
        "$PACKAGE_DIR/extern/blender/build_cycles/lib/libbf_intern_libc_compat.a",
        "$PACKAGE_DIR/extern/blender/build_cycles/lib/libbf_intern_guardedalloc.a",
        "$PACKAGE_DIR/extern/blender/build_cycles/lib/libbf_intern_sky.a",
        "$PACKAGE_DIR/extern/blender/build_cycles/lib/libextern_glog.a",
        "$PACKAGE_DIR/extern/blender/build_cycles/lib/libextern_gflags.a",
        "$PACKAGE_DIR/extern/blender/build_cycles/lib/libextern_cuew.a",
        "--end-group",

        "--exclude-libs=libextern_cuew.a",

        "$PACKAGE_DIR/extern/blender/lib/linux_x64/openimageio/lib/libOpenImageIO.so",
        "$PACKAGE_DIR/extern/blender/lib/linux_x64/openimageio/lib/libOpenImageIO_Util.so",
        "$PACKAGE_DIR/extern/blender/lib/linux_x64/opencolorio/lib/libOpenColorIO.so",
        "$PACKAGE_DIR/extern/blender/lib/linux_x64/embree/lib/libembree4.so",
        "$PACKAGE_DIR/extern/blender/lib/linux_x64/openimagedenoise/lib/libOpenImageDenoise.so",
        "$PACKAGE_DIR/extern/blender/lib/linux_x64/openexr/lib/libOpenEXR.so",
        "$PACKAGE_DIR/extern/blender/lib/linux_x64/openexr/lib/libOpenEXRCore.so",
        "$PACKAGE_DIR/extern/blender/lib/linux_x64/openexr/lib/libIex.so",
        "$PACKAGE_DIR/extern/blender/lib/linux_x64/openexr/lib/libIlmThread.so",
        "$PACKAGE_DIR/extern/blender/lib/linux_x64/imath/lib/libImath.so",
        "$PACKAGE_DIR/extern/blender/lib/linux_x64/opensubdiv/lib/libosdCPU.so",
        "$PACKAGE_DIR/extern/blender/lib/linux_x64/dpcpp/lib/libsycl.so",
        "$PACKAGE_DIR/extern/blender/lib/linux_x64/tbb/lib/libtbb.so",

        "$PACKAGE_DIR/extern/blender/lib/linux_x64/pugixml/lib/libpugixml.a",
        "$PACKAGE_DIR/extern/blender/lib/linux_x64/png/lib/libpng16.a",
        "$PACKAGE_DIR/extern/blender/lib/linux_x64/jpeg/lib/libjpeg.a",
        "$PACKAGE_DIR/extern/blender/lib/linux_x64/tiff/lib/libtiff.a",
        "$PACKAGE_DIR/extern/blender/lib/linux_x64/openjpeg/lib/libopenjp2.a",
        "$PACKAGE_DIR/extern/blender/lib/linux_x64/webp/lib/libwebp.a",
        "$PACKAGE_DIR/extern/blender/lib/linux_x64/zlib/lib/libz.a",
        "$PACKAGE_DIR/extern/blender/lib/linux_x64/zstd/lib/libzstd.a"
    ],

    "lflags-osx": [
        "-L$PACKAGE_DIR/build",
        "-L$PACKAGE_DIR/extern/blender/build_cycles/lib",

        "-rpath", "@executable_path/lib",
        "-rpath", "$PACKAGE_DIR/extern/blender/lib/macos_arm64/openimageio/lib",
        "-rpath", "$PACKAGE_DIR/extern/blender/lib/macos_arm64/opencolorio/lib",
        "-rpath", "$PACKAGE_DIR/extern/blender/lib/macos_arm64/embree/lib",
        "-rpath", "$PACKAGE_DIR/extern/blender/lib/macos_arm64/openimagedenoise/lib",
        "-rpath", "$PACKAGE_DIR/extern/blender/lib/macos_arm64/openexr/lib",
        "-rpath", "$PACKAGE_DIR/extern/blender/lib/macos_arm64/imath/lib",
        "-rpath", "$PACKAGE_DIR/extern/blender/lib/macos_arm64/opensubdiv/lib",
        "-rpath", "$PACKAGE_DIR/extern/blender/lib/macos_arm64/tbb/lib",

        "$PACKAGE_DIR/build/libcyclesc.a",
        "$PACKAGE_DIR/extern/blender/build_cycles/lib/libcycles_session.a",
        "$PACKAGE_DIR/extern/blender/build_cycles/lib/libcycles_scene.a",
        "$PACKAGE_DIR/extern/blender/build_cycles/lib/libcycles_kernel.a",
        "$PACKAGE_DIR/extern/blender/build_cycles/lib/libcycles_device.a",
        "$PACKAGE_DIR/extern/blender/build_cycles/lib/libcycles_integrator.a",
        "$PACKAGE_DIR/extern/blender/build_cycles/lib/libcycles_bvh.a",
        "$PACKAGE_DIR/extern/blender/build_cycles/lib/libcycles_subd.a",
        "$PACKAGE_DIR/extern/blender/build_cycles/lib/libcycles_graph.a",
        "$PACKAGE_DIR/extern/blender/build_cycles/lib/libcycles_util.a",
        "$PACKAGE_DIR/extern/blender/build_cycles/lib/libbf_intern_guardedalloc.a",
        "$PACKAGE_DIR/extern/blender/build_cycles/lib/libbf_intern_sky.a",
        "$PACKAGE_DIR/extern/blender/build_cycles/lib/libextern_glog.a",
        "$PACKAGE_DIR/extern/blender/build_cycles/lib/libextern_gflags.a",

        "$PACKAGE_DIR/extern/blender/lib/macos_arm64/openimageio/lib/libOpenImageIO.dylib",
        "$PACKAGE_DIR/extern/blender/lib/macos_arm64/openimageio/lib/libOpenImageIO_Util.dylib",
        "$PACKAGE_DIR/extern/blender/lib/macos_arm64/opencolorio/lib/libOpenColorIO.dylib",
        "$PACKAGE_DIR/extern/blender/lib/macos_arm64/embree/lib/libembree4.dylib",
        "$PACKAGE_DIR/extern/blender/lib/macos_arm64/openimagedenoise/lib/libOpenImageDenoise.dylib",
        "$PACKAGE_DIR/extern/blender/lib/macos_arm64/openexr/lib/libOpenEXR.dylib",
        "$PACKAGE_DIR/extern/blender/lib/macos_arm64/openexr/lib/libOpenEXRCore.dylib",
        "$PACKAGE_DIR/extern/blender/lib/macos_arm64/openexr/lib/libIex.dylib",
        "$PACKAGE_DIR/extern/blender/lib/macos_arm64/openexr/lib/libIlmThread.dylib",
        "$PACKAGE_DIR/extern/blender/lib/macos_arm64/imath/lib/libImath.dylib",
        "$PACKAGE_DIR/extern/blender/lib/macos_arm64/opensubdiv/lib/libosdCPU.dylib",
        "$PACKAGE_DIR/extern/blender/lib/macos_arm64/tbb/lib/libtbb.dylib",

        "$PACKAGE_DIR/extern/blender/lib/macos_arm64/pugixml/lib/libpugixml.a",
        "$PACKAGE_DIR/extern/blender/lib/macos_arm64/png/lib/libpng.a",
        "$PACKAGE_DIR/extern/blender/lib/macos_arm64/jpeg/lib/libjpeg.a",
        "$PACKAGE_DIR/extern/blender/lib/macos_arm64/tiff/lib/libtiff.a",
        "$PACKAGE_DIR/extern/blender/lib/macos_arm64/openjpeg/lib/libopenjp2.a",
        "$PACKAGE_DIR/extern/blender/lib/macos_arm64/webp/lib/libwebp.a",
        "$PACKAGE_DIR/extern/blender/lib/macos_arm64/zstd/lib/libzstd.a",

        "-framework", "Foundation",
        "-framework", "IOKit",
        "-framework", "Carbon",
        "-framework", "Accelerate",
        "-framework", "Metal",
        "-framework", "MetalKit",
        "-framework", "MetalPerformanceShaders",
        "-framework", "QuartzCore"
    ],

    "libs-linux":   ["stdc++", "pthread", "m", "dl", "z"],
    "libs-osx":     ["c++", "pthread", "m", "z"],
    "libs-windows": [
        "cyclesc",
        "cycles_session",
        "cycles_scene",
        "cycles_kernel",
        "cycles_device",
        "cycles_integrator",
        "cycles_bvh",
        "cycles_subd",
        "cycles_graph",
        "cycles_util",
        "bf_intern_guardedalloc",
        "bf_intern_sky",
        "extern_glog",
        "extern_gflags",
        "OpenImageIO",
        "OpenImageIO_Util",
        "OpenColorIO",
        "tbb12",
        "embree4",
        "openimagedenoise",
        "OpenEXR",
        "OpenEXRCore",
        "Iex",
        "IlmThread",
        "Imath",
        "pugixml",
        "libpng",
        "libjpeg",
        "libtiff",
        "openjp2",
        "libwebp",
        "libz_st",
        "zstd_static",
        "Shlwapi",
        "Version",
        "Psapi",
        "ucrt",
        "msvcrt"
    ],
    "lflags-windows": [
        "/NODEFAULTLIB:MSVCRTD",
        "/LIBPATH:$PACKAGE_DIR/build/Release",
        "/LIBPATH:$PACKAGE_DIR/build/Debug",
        "/LIBPATH:$PACKAGE_DIR/extern/blender/build_cycles/lib/Release",
        "/LIBPATH:$PACKAGE_DIR/extern/blender/build_cycles/lib/Debug",
        "/LIBPATH:$PACKAGE_DIR/extern/blender/lib/windows_x64/openimageio/lib",
        "/LIBPATH:$PACKAGE_DIR/extern/blender/lib/windows_x64/opencolorio/lib",
        "/LIBPATH:$PACKAGE_DIR/extern/blender/lib/windows_x64/tbb/lib",
        "/LIBPATH:$PACKAGE_DIR/extern/blender/lib/windows_x64/embree/lib",
        "/LIBPATH:$PACKAGE_DIR/extern/blender/lib/windows_x64/openimagedenoise/lib",
        "/LIBPATH:$PACKAGE_DIR/extern/blender/lib/windows_x64/openexr/lib",
        "/LIBPATH:$PACKAGE_DIR/extern/blender/lib/windows_x64/imath/lib",
        "/LIBPATH:$PACKAGE_DIR/extern/blender/lib/windows_x64/pugixml/lib",
        "$PACKAGE_DIR/extern/blender/lib/windows_x64/opensubdiv/lib/osdCPU.lib",
        "/LIBPATH:$PACKAGE_DIR/extern/blender/lib/windows_x64/png/lib",
        "/LIBPATH:$PACKAGE_DIR/extern/blender/lib/windows_x64/jpeg/lib",
        "/LIBPATH:$PACKAGE_DIR/extern/blender/lib/windows_x64/tiff/lib",
        "/LIBPATH:$PACKAGE_DIR/extern/blender/lib/windows_x64/openjpeg/lib",
        "/LIBPATH:$PACKAGE_DIR/extern/blender/lib/windows_x64/webp/lib",
        "/LIBPATH:$PACKAGE_DIR/extern/blender/lib/windows_x64/zlib/lib",
        "/LIBPATH:$PACKAGE_DIR/extern/blender/lib/windows_x64/zstd/lib"
    ]
}
